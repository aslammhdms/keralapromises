---
interface Props {
  promiseId?: string;
  label?: string;
  variant?: "link" | "button";
}

const TALLY_FORM_URL = "https://tally.so/r/keralapromises-tip";

const {
  promiseId,
  label = "Submit an update",
  variant = "link",
} = Astro.props;

const url = promiseId
  ? `${TALLY_FORM_URL}?promise=${encodeURIComponent(promiseId)}`
  : TALLY_FORM_URL;
---

{variant === "button" ? (
  <a
    href={url}
    rel="noopener noreferrer"
    target="_blank"
    class="font-ui inline-flex items-center gap-2 rounded-sm border border-ink-1 bg-ink-1 px-4 py-2 text-sm font-medium text-paper-1 no-underline hover:bg-ink-2"
  >
    {label}
  </a>
) : (
  <a
    href={url}
    rel="noopener noreferrer"
    target="_blank"
    class="font-ui text-sm text-ink-2 hover:text-ink-1"
  >
    {label}
  </a>
)}
