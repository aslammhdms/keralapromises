---
import type { Status } from "../content/config";
import { STATUS_ICON, STATUS_LABEL_EN, STATUS_LABEL_ML } from "../lib/status";
import { DEFAULT_LOCALE, type Locale } from "../lib/i18n";

interface Props {
  status: Status;
  locale?: Locale;
  size?: "sm" | "md" | "lg";
}

const { status, locale = DEFAULT_LOCALE, size = "md" } = Astro.props;

const label = locale === "ml" ? STATUS_LABEL_ML[status] : STATUS_LABEL_EN[status];
const icon = STATUS_ICON[status];

const sizeClass = {
  sm: "text-xs px-2 py-0.5 gap-1.5",
  md: "text-sm px-2.5 py-1 gap-2",
  lg: "text-base px-3 py-1.5 gap-2",
}[size];

const statusStyle: Record<Status, string> = {
  pending:     "bg-pending-bg text-pending-text border-pending-border",
  in_progress: "bg-progress-bg text-progress-text border-progress-border",
  fulfilled:   "bg-fulfilled-bg text-fulfilled-text border-fulfilled-border",
  evaded:      "bg-evaded-bg text-evaded-text border-evaded-border",
};
---

<span
  class:list={[
    "font-ui inline-flex items-center rounded-full border font-medium tnum",
    sizeClass,
    statusStyle[status],
  ]}
  data-status={status}
>
  <span aria-hidden="true" class="status-glyph">{icon}</span>
  <span>{label}</span>
</span>
