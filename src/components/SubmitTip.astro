---
interface Props {
  promiseId?: string;
  label?: string;
  variant?: "link" | "button";
}

// The Tally form URL is owned by the editors. Set a real URL here before
// going to production. The query parameter pre-fills the promise ID field
// in the form when the visitor clicks through from a promise detail page.
const TALLY_FORM_URL = "https://tally.so/r/keralapromises-tip";

const {
  promiseId,
  label = "Submit an update",
  variant = "link",
} = Astro.props;

const url = promiseId
  ? `${TALLY_FORM_URL}?promise=${encodeURIComponent(promiseId)}`
  : TALLY_FORM_URL;
---

{variant === "button" ? (
  <a
    href={url}
    rel="noopener noreferrer"
    target="_blank"
    class="inline-flex items-center gap-2 rounded-md border border-neutral-900 bg-neutral-900 px-4 py-2 text-sm font-medium text-white hover:bg-neutral-800"
  >
    {label}
  </a>
) : (
  <a
    href={url}
    rel="noopener noreferrer"
    target="_blank"
    class="text-sm underline underline-offset-2 hover:text-neutral-900"
  >
    {label}
  </a>
)}
