# Cloudflare Pages — response headers.
# Documentation: https://developers.cloudflare.com/pages/configuration/headers/

# Sensible defaults for every response.
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), interest-cohort=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

# Astro emits content-hashed asset filenames; these are safe to cache forever.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Pagefind index files are content-hashed too.
/pagefind/*
  Cache-Control: public, max-age=31536000, immutable

# JSON API and RSS feed — short cache so edits propagate within minutes.
/api/promises.json
  Cache-Control: public, max-age=300, s-maxage=300
  Access-Control-Allow-Origin: *

/rss.xml
  Cache-Control: public, max-age=300, s-maxage=300
