---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import StatusBadge from "../../components/StatusBadge.astro";
import StatusTimeline from "../../components/StatusTimeline.astro";
import CategoryPill from "../../components/CategoryPill.astro";
import EditOnGitHub from "../../components/EditOnGitHub.astro";
import SubmitTip from "../../components/SubmitTip.astro";
import { formatLongDate } from "../../lib/dates";

export async function getStaticPaths() {
  const promises = await getCollection("promises");
  return promises.map((promise) => ({
    params: { slug: promise.data.slug },
    props: { promise },
  }));
}

const { promise } = Astro.props;
const data = promise.data;
const { Content } = await render(promise);

const latestUpdate = data.status_updates[data.status_updates.length - 1];
const sourceFile = `src/content/promises/${promise.id}.mdx`;

const allPromises = await getCollection("promises");
const related = allPromises
  .filter(
    (p) =>
      p.data.id !== data.id &&
      p.data.category === data.category,
  )
  .slice(0, 3);

const initialUpdate = data.status_updates[0];

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: data.title_en,
  datePublished: initialUpdate.date.toISOString(),
  dateModified: latestUpdate.date.toISOString(),
  author: { "@type": "Organization", name: "Kerala Promises editors" },
  publisher: { "@type": "Organization", name: "Kerala Promises" },
  about: data.category,
  url: `https://keralapromises.in/promises/${data.slug}`,
  license: "https://creativecommons.org/licenses/by-sa/4.0/",
};
---

<BaseLayout
  title={data.title_en}
  description={`${data.title_en}. Status: ${data.current_status}. Tracked since the start of the Kerala UDF 2026 term.`}
  schema={articleSchema}
>
  <article>
    <header class="border-b border-rule">
      <div class="mx-auto max-w-4xl px-4 py-12 sm:px-6 sm:py-16">
        <div class="flex flex-wrap items-center gap-3">
          <span class="font-ui tnum text-micro uppercase tracking-wider text-ink-3">
            {data.id.replace("udf-2026-", "Promise #")}
          </span>
          <span aria-hidden="true" class="text-ink-4">·</span>
          <CategoryPill category={data.category} />
          {data.flagship && (
            <>
              <span aria-hidden="true" class="text-ink-4">·</span>
              <span class="font-ui text-micro uppercase tracking-wider text-ink-3">
                Flagship
              </span>
            </>
          )}
        </div>

        <h1 class="font-display measure-prose mt-4 text-display-s leading-tight text-ink-1">
          {data.title_en}
        </h1>

        {data.title_ml && (
          <p
            lang="ml"
            class="font-malayalam mt-3 measure-prose text-h2 leading-snug text-ink-2"
          >
            {data.title_ml}
          </p>
        )}

        <div class="mt-8 flex flex-wrap items-center gap-x-6 gap-y-3">
          <StatusBadge status={data.current_status} size="lg" />
          <div class="font-ui text-small text-ink-3">
            <span class="text-ink-2">Last updated</span>
            <span class="tnum ml-1 text-ink-1">
              {formatLongDate(latestUpdate.date, "en")}
            </span>
          </div>
          {data.target?.deadline && (
            <div class="font-ui text-small text-ink-3">
              <span class="text-ink-2">Promised by</span>
              <span class="tnum ml-1 text-ink-1">
                {formatLongDate(data.target.deadline, "en")}
              </span>
            </div>
          )}
        </div>
      </div>
    </header>

    <div class="mx-auto max-w-4xl px-4 py-12 sm:px-6">
      <div class="grid grid-cols-1 gap-x-12 gap-y-10 lg:grid-cols-[1fr_18rem]">
        <div>
          <section aria-labelledby="manifesto-heading">
            <h2 id="manifesto-heading" class="eyebrow">
              From the manifesto
            </h2>
            <blockquote class="font-body measure-prose mt-3 border-l-2 border-rule-2 bg-paper-2 px-5 py-4 text-body italic leading-relaxed text-ink-1">
              “{initialUpdate.evidence[0]?.excerpt_en}”
            </blockquote>
            <p class="font-ui mt-3 text-small text-ink-3">
              UDF 2026 manifesto
              {data.manifesto_page && (
                <>, page <span class="tnum">{data.manifesto_page}</span></>
              )}
              {!data.manifesto_page && (
                <span class="italic"> · page reference pending verification</span>
              )}
              · published <span class="tnum">{formatLongDate(initialUpdate.evidence[0]!.published, "en")}</span>
            </p>
          </section>

          <section class="font-body measure-prose mt-12 text-body leading-relaxed text-ink-1 prose-em prose-h2 prose-h3 prose-p">
            <Content />
          </section>

          <section aria-labelledby="timeline-heading" class="mt-16">
            <header class="border-b border-rule pb-3">
              <h2 id="timeline-heading" class="font-display text-h1 leading-snug text-ink-1">
                Status timeline
              </h2>
              <p class="font-body mt-2 text-small text-ink-3">
                Every status change ever recorded for this promise, newest first. Each change cites its evidence.
              </p>
            </header>
            <div class="mt-8">
              <StatusTimeline updates={data.status_updates} locale="en" />
            </div>
          </section>
        </div>

        <aside class="space-y-8 lg:sticky lg:top-8 lg:self-start">
          <div class="border-t border-rule pt-5">
            <p class="eyebrow">Submit an update</p>
            <p class="font-body mt-2 text-small text-ink-2">
              Have you seen news about this promise? Tell us with a source from the methodology.
            </p>
            <div class="mt-4">
              <SubmitTip promiseId={data.id} variant="button" />
            </div>
          </div>

          <div class="border-t border-rule pt-5">
            <p class="eyebrow">Transparency</p>
            <p class="font-body mt-2 text-small text-ink-2">
              The full history of this promise is in Git. Anyone can see what changed, when, and by whom.
            </p>
            <div class="mt-4">
              <EditOnGitHub path={sourceFile} />
            </div>
          </div>

          {related.length > 0 && (
            <div class="border-t border-rule pt-5">
              <p class="eyebrow">Related promises</p>
              <ul class="mt-3 space-y-3">
                {related.map((r) => (
                  <li>
                    <a
                      href={`/promises/${r.data.slug}`}
                      class="font-body text-small leading-snug text-ink-1 no-underline hover:underline hover:decoration-rule-2"
                    >
                      {r.data.title_en}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </aside>
      </div>
    </div>
  </article>
</BaseLayout>
