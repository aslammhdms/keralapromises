---
import BaseLayout from "./BaseLayout.astro";
import { formatLongDate } from "../lib/dates";
import type { Locale } from "../lib/i18n";

interface Props {
  eyebrow: string;
  title: string;
  description: string;
  updated: Date;
  locale?: Locale;
}

const { eyebrow, title, description, updated, locale = "en" } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <article class="mx-auto max-w-3xl px-4 py-12 sm:px-6 sm:py-16">
    <header class="border-b border-rule pb-8">
      <p class="eyebrow">{eyebrow}</p>
      <h1 class="font-display mt-3 text-display-s leading-tight text-ink-1">
        {title}
      </h1>
      <p class="font-ui mt-4 text-small text-ink-3 tnum">
        Updated {formatLongDate(updated, locale)}
      </p>
    </header>

    <div class="hp-prose mt-10">
      <slot />
    </div>
  </article>
</BaseLayout>

<style is:global>
  .hp-prose {
    font-family: var(--font-body);
    color: var(--color-ink-1);
    font-size: var(--text-body);
    line-height: 1.7;
  }
  .hp-prose h2 {
    font-family: var(--font-display);
    font-size: var(--text-h1);
    line-height: 1.18;
    color: var(--color-ink-1);
    margin-top: 3rem;
    margin-bottom: 0.75rem;
    padding-top: 0.5rem;
    border-top: 1px solid var(--color-rule);
  }
  .hp-prose h2:first-child { border-top: 0; margin-top: 0; padding-top: 0; }
  .hp-prose h3 {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    line-height: 1.22;
    color: var(--color-ink-1);
    margin-top: 1.75rem;
    margin-bottom: 0.5rem;
  }
  .hp-prose h4 {
    font-family: var(--font-display);
    font-size: var(--text-h3);
    line-height: 1.4;
    color: var(--color-ink-1);
    margin-top: 1.5rem;
    margin-bottom: 0.25rem;
  }
  .hp-prose p,
  .hp-prose ul,
  .hp-prose ol,
  .hp-prose blockquote {
    margin-top: 1rem;
    margin-bottom: 1rem;
    max-width: 65ch;
  }
  .hp-prose ul,
  .hp-prose ol { padding-left: 1.5rem; }
  .hp-prose ul li { list-style: disc; }
  .hp-prose ol li { list-style: decimal; }
  .hp-prose li + li { margin-top: 0.4rem; }
  .hp-prose strong { font-weight: 600; color: var(--color-ink-1); }
  .hp-prose a {
    color: var(--color-accent);
    text-decoration-thickness: 1px;
    text-underline-offset: 0.18em;
  }
  .hp-prose code {
    font-family: var(--font-mono);
    font-size: 0.92em;
    background: var(--color-paper-2);
    border: 1px solid var(--color-rule);
    padding: 0.05rem 0.35rem;
    border-radius: 2px;
  }
  .hp-prose blockquote {
    border-left: 2px solid var(--color-rule-2);
    padding-left: 1rem;
    color: var(--color-ink-2);
    font-style: italic;
  }
  .hp-prose hr {
    margin: 2rem 0;
    border: 0;
    border-top: 1px solid var(--color-rule);
  }
</style>
