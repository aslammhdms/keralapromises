---
import type { Category } from "../content/config";
import { getEntry } from "astro:content";
import { DEFAULT_LOCALE, type Locale } from "../lib/i18n";

interface Props {
  category: Category;
  locale?: Locale;
  asLink?: boolean;
}

const { category, locale = DEFAULT_LOCALE, asLink = true } = Astro.props;

const entry = await getEntry("categories", category);
const label = entry
  ? locale === "ml"
    ? entry.data.name_ml
    : entry.data.name_en
  : category;

const Tag = asLink ? "a" : "span";
const href = asLink ? `/category/${category}` : undefined;
---

<Tag
  href={href}
  class="font-ui inline-flex items-center rounded-full border border-rule bg-paper-1 px-2.5 py-0.5 text-xs font-medium text-ink-2 no-underline hover:border-rule-2 hover:bg-paper-2 hover:text-ink-1"
>
  {label}
</Tag>
