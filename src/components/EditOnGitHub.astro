---
interface Props {
  path: string;
  branch?: string;
  repo?: string;
  label?: string;
}

const {
  path,
  branch = "main",
  repo = "keralapromises/keralapromises",
  label = "Edit on GitHub",
} = Astro.props;

const href = `https://github.com/${repo}/edit/${branch}/${path}`;
const historyHref = `https://github.com/${repo}/commits/${branch}/${path}`;
---

<div class="font-ui flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-ink-2">
  <a href={href} rel="noopener noreferrer" class="text-ink-2 hover:text-ink-1">
    {label}
  </a>
  <span aria-hidden="true" class="text-ink-4">·</span>
  <a href={historyHref} rel="noopener noreferrer" class="text-ink-2 hover:text-ink-1">
    View edit history
  </a>
</div>
