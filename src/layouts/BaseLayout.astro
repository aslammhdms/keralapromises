---
import "../styles/global.css";
import DisclaimerBanner from "../components/DisclaimerBanner.astro";
import LanguageToggle from "../components/LanguageToggle.astro";
import TricolorStripe from "../components/TricolorStripe.astro";
import { DEFAULT_LOCALE, type Locale, t } from "../lib/i18n";

interface Props {
  title: string;
  description: string;
  locale?: Locale;
  canonical?: string;
  ogImage?: string;
  schema?: object;
}

const {
  title,
  description,
  locale = DEFAULT_LOCALE,
  canonical,
  ogImage = "/og-preview.webp",
  schema,
} = Astro.props;

const fullTitle = title === "Kerala Promises"
  ? title
  : `${title} — Kerala Promises`;

const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
const ogImageUrl = new URL(ogImage, Astro.site).toString();
const currentPath = Astro.url.pathname;

function navLinkClass(href: string): string {
  const active = currentPath === href || (href !== "/" && currentPath.startsWith(href));
  return active
    ? "border-b border-ink-1 pb-1 font-medium text-ink-1"
    : "border-b border-transparent pb-1 text-ink-2 hover:text-ink-1";
}
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#fdfcf8" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content="Kerala Promises" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Kerala Promises — status updates"
      href="/rss.xml"
    />

    {schema && (
      <script
        is:inline
        type="application/ld+json"
        set:html={JSON.stringify(schema)}
      />
    )}
  </head>

  <body>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded focus:bg-ink-1 focus:px-4 focus:py-2 focus:text-paper-1"
    >
      Skip to main content
    </a>

    <TricolorStripe />
    <DisclaimerBanner locale={locale} />

    {/* N7: compact wordmark + 4 inline links, no button-right.
        Civic / journalistic register — no CTA in the masthead. */}
    <header class="border-b border-rule">
      <div class="mx-auto flex max-w-6xl flex-wrap items-baseline justify-between gap-x-8 gap-y-2 px-4 py-5 sm:px-6">
        <a
          href="/"
          class="group flex flex-col gap-0.5 text-ink-1 no-underline hover:text-ink-1"
        >
          <span class="font-display text-xl font-semibold tracking-tight text-ink-1">
            {t(locale, "site.name")}
          </span>
          <span class="font-ui text-[0.7rem] uppercase tracking-[0.14em] text-ink-3">
            {t(locale, "site.subtitle")}
          </span>
        </a>
        <nav aria-label="Primary" class="font-ui flex flex-wrap items-center gap-x-5 gap-y-2 text-sm">
          <a href="/promises" class={`no-underline ${navLinkClass("/promises")}`}>{t(locale, "nav.promises")}</a>
          <a href="/cabinet" class={`no-underline ${navLinkClass("/cabinet")}`}>{t(locale, "nav.cabinet")}</a>
          <a href="/latest" class={`no-underline ${navLinkClass("/latest")}`}>{t(locale, "nav.latest")}</a>
          <a href="/methodology" class={`no-underline ${navLinkClass("/methodology")}`}>{t(locale, "nav.methodology")}</a>
          <a href="/about" class={`no-underline ${navLinkClass("/about")}`}>{t(locale, "nav.about")}</a>
          <a href="/faq" class={`no-underline ${navLinkClass("/faq")}`}>{t(locale, "nav.faq")}</a>
          <LanguageToggle locale={locale} />
        </nav>
      </div>
    </header>

    <main id="main">
      <slot />
    </main>

    {/* Ft5 Statement: the disclaimer + good-faith line is the page's
        last word. Practical chips (RSS / JSON / GitHub) tucked below. */}
    <footer class="mt-24 border-t border-rule bg-paper-2">
      <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
        <p class="font-display measure-prose text-h3 leading-relaxed text-ink-1">
          {t(locale, "site.disclaimer")}
        </p>
        <p class="font-body mt-6 measure-prose text-sm leading-relaxed text-ink-2">
          {t(locale, "site.good_faith")}
        </p>
        <div class="font-ui mt-10 flex flex-wrap items-center gap-x-5 gap-y-2 border-t border-rule pt-6 text-micro text-ink-3 uppercase tracking-wider">
          <span>{t(locale, "footer.code_licence")}</span>
          <span aria-hidden="true">·</span>
          <span>{t(locale, "footer.content_licence")}</span>
          <span aria-hidden="true">·</span>
          <a
            href="https://github.com/keralapromises/keralapromises"
            class="text-ink-2 no-underline hover:text-ink-1"
            rel="noopener noreferrer"
          >GitHub</a>
          <span aria-hidden="true">·</span>
          <a href="/rss.xml" class="text-ink-2 no-underline hover:text-ink-1">RSS</a>
          <span aria-hidden="true">·</span>
          <a href="/api/promises.json" class="text-ink-2 no-underline hover:text-ink-1">JSON API</a>
        </div>
      </div>
    </footer>
  </body>
</html>
