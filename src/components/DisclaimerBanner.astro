---
import { DEFAULT_LOCALE, type Locale, t } from "../lib/i18n";

interface Props {
  locale?: Locale;
}

const { locale = DEFAULT_LOCALE } = Astro.props;
---

<aside
  id="disclaimer-banner"
  role="note"
  aria-label="Site disclaimer"
  class="border-b border-ink-1 bg-ink-1 text-paper-1"
>
  <div class="mx-auto flex max-w-6xl items-start gap-4 px-4 py-3 sm:px-6">
    <p class="font-ui flex-1 text-sm leading-6">
      {t(locale, "site.disclaimer")}
    </p>
    <button
      type="button"
      data-dismiss
      aria-controls="disclaimer-banner"
      aria-label="Dismiss for this page view"
      class="font-ui ml-2 shrink-0 rounded border border-paper-1/30 px-2 py-0.5 text-xs text-paper-2 hover:bg-paper-1/10 hover:text-paper-1"
    >
      Dismiss
    </button>
  </div>
</aside>

<script>
  const banner = document.getElementById("disclaimer-banner");
  banner?.querySelector("[data-dismiss]")?.addEventListener("click", () => {
    banner.remove();
  });
</script>
