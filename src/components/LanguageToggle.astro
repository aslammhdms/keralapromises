---
import { DEFAULT_LOCALE, type Locale, t, PHASE_1_LOCALES_ENABLED } from "../lib/i18n";

interface Props {
  locale?: Locale;
}

const { locale = DEFAULT_LOCALE } = Astro.props;

const malayalamEnabled = PHASE_1_LOCALES_ENABLED.includes("ml");
---

<button
  type="button"
  aria-pressed={locale === "ml"}
  aria-disabled={!malayalamEnabled}
  disabled={!malayalamEnabled}
  title={!malayalamEnabled ? t(locale, "language.unavailable") : undefined}
  class:list={[
    "font-ui ml-2 inline-flex items-center rounded border border-rule px-2.5 py-1 text-xs font-medium",
    !malayalamEnabled && "cursor-not-allowed text-ink-4",
    malayalamEnabled && "text-ink-2 hover:border-rule-2 hover:bg-paper-2",
  ]}
>
  EN <span aria-hidden="true" class="mx-1 text-ink-4">/</span> <span lang="ml">മ</span>
</button>
