---
import BaseLayout from "../layouts/BaseLayout.astro";
import { t } from "../lib/i18n";
---

<BaseLayout
  title="Page not found"
  description="The page you asked for is not on this site."
>
  <section class="mx-auto max-w-3xl px-4 py-24 text-center sm:px-6 sm:py-32">
    <p class="eyebrow">404</p>
    <h1 class="font-display mt-3 text-display-s leading-tight text-ink-1">
      {t("en", "error.404.title")}
    </h1>
    <p
      lang="ml"
      class="font-malayalam mx-auto mt-2 text-h3 text-ink-3"
    >
      ഞങ്ങൾക്ക് ആ പേജ് കണ്ടെത്താൻ കഴിഞ്ഞില്ല
    </p>
    <p class="font-body mx-auto mt-6 max-w-prose text-body text-ink-2">
      {t("en", "error.404.body")}
    </p>
    <div class="mt-10 flex flex-wrap items-center justify-center gap-x-6 gap-y-3">
      <a
        href="/"
        class="font-ui inline-flex items-center gap-2 rounded-sm border border-ink-1 bg-ink-1 px-4 py-2 text-sm font-medium text-paper-1 no-underline hover:bg-ink-2"
      >
        {t("en", "error.404.home")}
      </a>
      <a href="/promises" class="font-ui text-small text-ink-2 no-underline hover:text-ink-1">
        Browse all promises
      </a>
      <a href="/methodology" class="font-ui text-small text-ink-2 no-underline hover:text-ink-1">
        Read the methodology
      </a>
    </div>
  </section>
</BaseLayout>
